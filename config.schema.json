{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ai-brand-monitor config",
  "description": "Configuration for monitoring brand visibility across AI search surfaces.",
  "type": "object",
  "required": ["brand", "queries", "prompts", "targets"],
  "properties": {
    "brand": {
      "type": "object",
      "description": "Your brand information.",
      "required": ["name", "domain"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Primary brand name used for matching in AI responses."
        },
        "domain": {
          "type": "string",
          "minLength": 1,
          "description": "Primary domain (e.g. example.com). Used to detect citation links."
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Alternative names, abbreviations, or spellings to also match."
        }
      },
      "additionalProperties": false
    },
    "competitors": {
      "type": "array",
      "description": "Competitor brands to track alongside yours.",
      "items": {
        "type": "object",
        "required": ["name", "domain"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Competitor brand name."
          },
          "domain": {
            "type": "string",
            "minLength": 1,
            "description": "Competitor domain."
          }
        },
        "additionalProperties": false
      }
    },
    "locale": {
      "type": "object",
      "description": "Language and country settings for queries.",
      "properties": {
        "language": {
          "type": "string",
          "default": "ja",
          "description": "ISO 639-1 language code."
        },
        "country": {
          "type": "string",
          "default": "JP",
          "description": "ISO 3166-1 alpha-2 country code."
        }
      },
      "additionalProperties": false
    },
    "queries": {
      "type": "array",
      "description": "Search queries to send to AI surfaces.",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "prompts": {
      "type": "array",
      "description": "Structured prompts with category metadata.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "category"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique identifier for this prompt."
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "The prompt text to send to AI surfaces."
          },
          "category": {
            "type": "string",
            "enum": ["purchase_intent", "info_gathering", "brand_direct", "neutral"],
            "description": "Intent category for analysis grouping."
          }
        },
        "additionalProperties": false
      }
    },
    "targets": {
      "type": "array",
      "description": "AI surfaces to monitor.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "google_aio",
          "google_ai_mode",
          "perplexity",
          "chatgpt_web",
          "gemini_web",
          "claude"
        ]
      }
    },
    "output": {
      "type": "object",
      "description": "Output format and destination settings.",
      "properties": {
        "dir": {
          "type": "string",
          "description": "Output directory path (relative to config file)."
        },
        "sheets": {
          "type": "object",
          "description": "Google Sheets export settings.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Google Sheets export."
            },
            "spreadsheet_id": {
              "type": "string",
              "description": "Existing Google Sheets spreadsheet ID to append to. If omitted, a new spreadsheet is created."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
